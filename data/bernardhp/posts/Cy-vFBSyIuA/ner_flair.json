f\u30b3\u30b9\u30d1\u795e\u3002 \u2061 \u5e97\u54e1\u3055\u3093\u3082\u512a\u3057\u304f\u3066\u7f8e\u5473\u3057\u304b\u3063\u305f\u304b\u3089\u307e\u305f\u798f\u5ca1\u3067\u98df\u3079\u306b\u884c\u304d\u305f\u3044\u304a\u5e97\u306e\u3072\u3068\u3064\uff01 \u2061 \u8d85\u304a\u3059\u3059\u3081\uff01 \u2061 CAFE STAND 10.8 \u2061 One of the fluffiest pancakes in Fukuoka\ud83e\udd5e   The \u201cMatcha daifuku pancake\u201d is filled with matcha sauce and topped with matcha cream, mochi, and matcha powder\ud83c\udf75 \u2061 They use matcha from a famous Japanese tea shop in Fukuoka, slightly bitter and rich in flavor. \u2061 All pancakes are freshly made to order, and you can get a plate of 3 pancakes from 600yen! \u2061 Highly recommended! \u2061 \u30ab\u30d5\u30a7\u30b9\u30bf\u30f3\u30c910.8 \ud81a\udc3f \u798f\u5ca1\u770c\u4e45\u7559\u7c73\u5e02\u901a\u753a107\u2212\uff11\uff13 \u9ad8\u5c71\u30d3\u30eb 1F \u231a\ufe0e 11:00\u301c18:00,\u6c34\u66dc\u306e\u307f11:00\u301c17:00 \u2611\ufe0e \u98a8\u6d41\u306a\u62b9\u8336\u5927\u798f 1000\u5186 \u2061 \u203b\u55b6\u696d\u6642\u9593\u3084\u30e1\u30cb\u30e5\u30fc\u306e\u4fa1\u683c\u306f\u5909\u66f4\u3055\u308c\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002\u4e8b\u524d\u306b\u304a\u5e97\u306e\u30a2\u30ab\u30a6\u30f3\u30c8\u3084\u516c\u5f0fHP\u306e\u3054\u78ba\u8a8d\u3092\u304a\u9858\u3044\u81f4\u3057\u307e\u3059\ud83e\udd32 \u2061 #cafestand108 #\u30ab\u30d5\u30a7\u30b9\u30bf\u30f3\u30c9\u30b8\u30e5\u30c3\u30c6\u30f3\u30cf\u30c1 #\u798f\u5ca1\u30ab\u30d5\u30a7 #\u798f\u5ca1\u30b0\u30eb\u30e1 #\u798f\u5ca1 #\u798f\u5ca1\u65c5\u884c #\u30d1\u30f3\u30b1\u30fc\u30ad #\u62b9\u8336\u30b9\u30a4\u30fc\u30c4 #\u4e45\u7559\u7c73\u30ab\u30d5\u30a7 #\u4e45\u7559\u7c73\u30b0\u30eb\u30e1 #japanesefood #japantrip #japantravel #japan",
